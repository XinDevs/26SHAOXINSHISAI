[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[branch "main"]
	vscode-merge-base = first/main
	remote = origin
	merge = refs/heads/main
[remote "first"]
	url = https://github.com/XinDevs/SmartPatrol.git
	fetch = +refs/heads/*:refs/remotes/first/*
[remote "origin"]
	url = https://github.com/XinDevs/SmartPatrol.git
	fetch = +refs/heads/*:refs/remotes/origin/*
